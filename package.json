{
  "name": "party-pupils",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenvx run -- concurrently -n db,stripe,next -c blue,magenta,green \"prisma dev\" \"./scripts/stripe-listen.sh\" \"sleep 3 && tsx scripts/guard-local-db.ts && prisma db push --accept-data-loss && next dev --webpack\"",
    "dev:prod": "dotenvx run -f .env.prod -- next dev --webpack",
    "build": "node scripts/strip-env-on-vercel.mjs && node scripts/prepare-ffmpeg.mjs && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:push:prod": "./scripts/db-push-prod.sh",
    "db:reset": "prisma db push --force-reset",
    "test": "TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5436/gigamusic_demo tsx scripts/run-tests.ts",
    "test:watch": "TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5436/gigamusic_demo tsx scripts/run-tests.ts --watch"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/lib-storage": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1042.0",
    "@base-ui/react": "^1.3.0",
    "@gigamusic/admin": "link:../gigamusic/packages/admin",
    "@gigamusic/audio": "link:../gigamusic/packages/audio",
    "@gigamusic/checkout": "link:../gigamusic/packages/checkout",
    "@gigamusic/config": "link:../gigamusic/packages/config",
    "@gigamusic/core": "link:../gigamusic/packages/core",
    "@gigamusic/db": "link:../gigamusic/packages/db",
    "@gigamusic/email": "link:../gigamusic/packages/email",
    "@gigamusic/links": "link:../gigamusic/packages/links",
    "@gigamusic/storage": "link:../gigamusic/packages/storage",
    "@gigamusic/ui": "link:../gigamusic/packages/ui",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.6.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@tiptap/extension-link": "^3.23.4",
    "@tiptap/pm": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "archiver": "^7.0.1",
    "class-variance-authority": "^0.7.1",
    "client-zip": "^2.5.0",
    "clsx": "^2.1.1",
    "ffmpeg-static": "^5.3.0",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "music-metadata": "^11.12.3",
    "next": "16.2.6",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.10.0",
    "shadcn": "^4.1.2",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.67.0",
    "@tailwindcss/postcss": "^4",
    "@types/archiver": "^7.0.0",
    "@types/node": "^22",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitest/ui": "^4.1.5",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "ffmpeg-static"
    ]
  }
}
