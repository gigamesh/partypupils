{
  "name": "party-pupils",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/dev-bootstrap.ts && dotenvx run -- concurrently -n stripe,next -c magenta,green \"./scripts/stripe-listen.sh\" \"next dev\"",
    "dev:prod": "dotenvx run -f .env.prod -- next dev",
    "build": "node scripts/strip-env-on-vercel.mjs && node scripts/prepare-ffmpeg.mjs && dotenvx run -- next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "dotenvx run -- drizzle-kit push --config drizzle.config.ts",
    "db:push:prod": "./scripts/db-push-prod.sh",
    "db:reset": "docker compose down -v",
    "db:seed": "dotenvx run -- bash -c 'psql \"$DATABASE_URL\" -f db/seed.sql'",
    "db:refresh-snapshot": "./scripts/refresh-snapshot.sh",
    "db:studio": "dotenvx run -- drizzle-kit studio --config drizzle.config.ts",
    "test": "tsx scripts/run-tests.ts",
    "test:watch": "tsx scripts/run-tests.ts --watch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/lib-storage": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1042.0",
    "@base-ui/react": "^1.3.0",
    "@gigamusic/admin": "^4.4.0",
    "@gigamusic/audio": "^4.3.0",
    "@gigamusic/checkout": "^4.4.0",
    "@gigamusic/core": "^4.2.0",
    "@gigamusic/db": "^4.4.0",
    "@gigamusic/email": "^4.2.0",
    "@gigamusic/links": "^4.4.0",
    "@gigamusic/storage": "^3.0.0",
    "@neondatabase/serverless": "^1.1.0",
    "@tiptap/extension-link": "^3.23.4",
    "@tiptap/pm": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "archiver": "^7.0.1",
    "botid": "^1.5.11",
    "class-variance-authority": "^0.7.1",
    "client-zip": "^2.5.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "ffmpeg-static": "^5.3.0",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "music-metadata": "^11.12.3",
    "next": "16.2.6",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.10.0",
    "shadcn": "^4.1.2",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.67.0",
    "@tailwindcss/postcss": "^4",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/ui": "^4.1.5",
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "ffmpeg-static"
    ]
  }
}
