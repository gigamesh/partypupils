generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ReleaseType {
  album
  single
}

enum OrderStatus {
  pending
  completed
  failed
}

model Release {
  id            Int         @id @default(autoincrement())
  name          String
  slug          String      @unique
  description   String?
  price         Int // cents — price for the full release
  type          ReleaseType
  coverImageUrl String?
  releasedAt    DateTime?
  isPublished   Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tracks     Track[]
  orderItems OrderItem[]

  @@map("releases")
}

model Track {
  id          Int      @id @default(autoincrement())
  releaseId   Int
  name        String
  price       Int // cents — price for individual track purchase
  trackNumber Int
  previewUrl  String?
  createdAt   DateTime @default(now())

  release    Release     @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  files      TrackFile[]
  orderItems OrderItem[]

  @@map("tracks")
}

model TrackFile {
  id         Int      @id @default(autoincrement())
  trackId    Int
  format     String // wav, mp3
  fileName   String
  storageKey String
  fileSize   Int?
  createdAt  DateTime @default(now())

  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@map("track_files")
}

model Order {
  id              Int         @id @default(autoincrement())
  stripeSessionId String?     @unique
  stripePaymentId String?
  email           String
  amountTotal     Int // cents
  status          OrderStatus @default(pending)
  createdAt       DateTime    @default(now())

  items          OrderItem[]
  downloadTokens DownloadToken[]

  @@index([email])
  @@map("orders")
}

model OrderItem {
  id        Int  @id @default(autoincrement())
  orderId   Int
  releaseId Int?
  trackId   Int?
  price     Int // cents, snapshot at purchase time

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  release Release? @relation(fields: [releaseId], references: [id])
  track   Track?   @relation(fields: [trackId], references: [id])

  @@map("order_items")
}

model DownloadToken {
  id        Int      @id @default(autoincrement())
  orderId   Int
  token     String   @unique @default(uuid())
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("download_tokens")
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

model Link {
  id        Int      @id @default(autoincrement())
  title     String
  url       String
  position  Int      @default(0)
  isVisible  Boolean  @default(true)
  showOnHero Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("links")
}
